# 服务端口
PORT=4000

# 数据库连接（本地开发用 SQLite，生产用 PostgreSQL）
# SQLite: file:./dev.db
# PostgreSQL: postgresql://user:password@localhost:5432/ideahub
DATABASE_URL="file:./dev.db"

# JWT 密钥
JWT_SECRET=your-super-secret-jwt-key-change-in-production

# 平台抽成比例
IDEA_FEE_RATE=0.10
AI_FEE_RATE=0.20

# AI 生成服务配置
# mock: 使用模板生成（本地开发）
# openai: 使用 OpenAI API
# glm: 使用智谱 GLM API
AI_PROVIDER=mock
OPENAI_API_KEY=
GLM_API_KEY=

# 文件存储配置
# local: 本地文件系统
# minio: MinIO 对象存储
STORAGE_TYPE=local
STORAGE_DIR=storage

# MinIO 配置（生产环境）
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_ACCESS_KEY=
MINIO_SECRET_KEY=
MINIO_BUCKET=ideahub
